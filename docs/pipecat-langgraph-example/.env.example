GYM_SUPPORT_MODEL=anthropic:claude-sonnet-4-6
ANTHROPIC_API_KEY=

OPENAI_API_KEY=

# --- LangSmith tracing ---
# The whole point of the demo: watch the handoffs in the trace tree.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pipecat-langgraph-example

OTEL_EXPORTER_OTLP_ENDPOINT=https://api.smith.langchain.com/otel
OTEL_EXPORTER_OTLP_HEADERS=x-api-key=<my-api-key>,Langsmith-Project=pipecat-langgraph-example
LANGSMITH_TRACING_MODE=otel
